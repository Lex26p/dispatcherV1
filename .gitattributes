# Dispatcher repository text normalization.
# Store source files with LF in git for stable GitHub/Linux behavior.
# Editors on Windows can still open and edit these files normally.

* text=auto eol=lf

# C++ source
*.h text eol=lf
*.hpp text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.cc text eol=lf
*.c text eol=lf

# CMake
CMakeLists.txt text eol=lf
*.cmake text eol=lf

# C# / Blazor
*.cs text eol=lf
*.razor text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.slnx text eol=lf

# Web frontend
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf

# SQL and docs
*.sql text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Scripts
*.ps1 text eol=lf
*.sh text eol=lf

# Windows command files
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.dll binary
*.exe binary
*.pdb binary