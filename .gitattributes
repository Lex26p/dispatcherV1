# Dispatcher repository text normalization.
# Store text files with LF in git and in the working tree.

* text=auto eol=lf

# C++ source
*.h text eol=lf
*.hpp text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.cc text eol=lf
*.c text eol=lf

# CMake
CMakeLists.txt text eol=lf
*.cmake text eol=lf

# C# / Blazor
*.cs text eol=lf
*.razor text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.slnx text eol=lf

# Web frontend
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf

# SQL and docs
*.sql text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Scripts
*.ps1 text eol=lf
*.sh text eol=lf
*.bat text eol=lf
*.cmd text eol=lf

# Config and misc text
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.config text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.dll binary
*.exe binary
*.pdb binary
*.lib binary
*.obj binary
*.bin binary
