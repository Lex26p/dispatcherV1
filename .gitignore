*.snupkg
project.lock.json
project.assets.json
*.nuget.props
*.nuget.targets

# Blazor / frontend generated files
frontend/**/bin/
frontend/**/obj/
frontend/**/dist/
frontend/**/node_modules/

# NuGet
.nuget/
packages/
*.nupkg
*.snupkg

# Rider / JetBrains
.idea/
*.sln.iml

# ReSharper
