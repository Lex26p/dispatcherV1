@page "/alarms"

@inject IDispatcherApiClient ApiClient

<PageTitle>Аварии - Dispatcher</PageTitle>

<div class="dispatcher-page">
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
            <div>
                <MudText Typo="Typo.h4" HtmlTag="h1">Аварии</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    Панель активных аварий Dispatcher.
                </MudText>
            </div>

            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined">
                Демо-данные
            </MudChip>
        </MudStack>

        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            На этой странице пока отображаются демо-аварии.
            Реальное подключение к `/api/alarms/active` будет добавлено позже.
        </MudAlert>

        <MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        Активные аварии
                    </MudText>
                    <MudText Typo="Typo.h5" Class="mt-1">
                        @_alarms.Count
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        Аварии в текущем демо-срезе.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        Требуют квитирования
                    </MudText>
                    <MudText Typo="Typo.h5" Class="mt-1">
                        @UnacknowledgedCount
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        Аварии, которые должен квитировать оператор.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        Критические
                    </MudText>
                    <MudText Typo="Typo.h5" Class="mt-1">
                        @CriticalCount
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        Активные аварии с критической важностью.
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="0" Class="dispatcher-card">
            <MudText Typo="Typo.h6">Активные аварии</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                Эта таблица моделирует будущую панель активных аварий.
            </MudText>

            <MudTable T="ActiveAlarmViewModel"
                      Items="_alarms"
                      Dense="true"
                      Hover="true"
                      Elevation="0"
                      Class="dispatcher-table">
                <HeaderContent>
                    <MudTh>Возникла</MudTh>
                    <MudTh>Объект</MudTh>
                    <MudTh>Источник</MudTh>
                    <MudTh>Важность</MudTh>
                    <MudTh>Приоритет</MudTh>
                    <MudTh>Состояние</MudTh>
                    <MudTh>Квитирование</MudTh>
                    <MudTh>Сообщение</MudTh>
                </HeaderContent>

                <RowTemplate Context="alarm">
                    <MudTd DataLabel="Возникла">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @alarm.RaisedAt.ToString("HH:mm:ss")
                        </MudText>
                    </MudTd>

                    <MudTd DataLabel="Объект">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @alarm.ObjectPath
                        </MudText>
                    </MudTd>

                    <MudTd DataLabel="Источник">
                        <MudText Typo="Typo.body2">@alarm.SourceName</MudText>
                    </MudTd>

                    <MudTd DataLabel="Важность">
                        <MudChip T="string"
                                 Color="@GetSeverityColor(alarm.Severity)"
                                 Variant="Variant.Filled"
                                 Size="Size.Small">
                            @FormatSeverity(alarm.Severity)
                        </MudChip>
                    </MudTd>

                    <MudTd DataLabel="Приоритет">
                        <MudChip T="string"
                                 Color="@GetPriorityColor(alarm.Priority)"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small">
                            @FormatPriority(alarm.Priority)
                        </MudChip>
                    </MudTd>

                    <MudTd DataLabel="Состояние">
                        <MudText Typo="Typo.body2">@FormatState(alarm.State)</MudText>
                    </MudTd>

                    <MudTd DataLabel="Квитирование">
                        <MudChip T="string"
                                 Color="@(alarm.Acknowledged ? Color.Success : Color.Warning)"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small">
                            @(alarm.Acknowledged ? "Квитировано" : "Требуется")
                        </MudChip>
                    </MudTd>

                    <MudTd DataLabel="Сообщение">
                        <MudText Typo="Typo.body2">@alarm.Message</MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudStack>
</div>

@code {
    private IReadOnlyList<ActiveAlarmViewModel> _alarms = [];

    private int UnacknowledgedCount =>
        _alarms.Count(alarm => !alarm.Acknowledged);

    private int CriticalCount =>
        _alarms.Count(alarm => string.Equals(alarm.Severity, "Critical", StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _alarms = await ApiClient.GetActiveAlarmsAsync();
    }

    private static Color GetSeverityColor(
        string severity
    )
    {
        return severity switch
        {
            "Critical" => Color.Error,
            "Warning" => Color.Warning,
            "Info" => Color.Info,
            _ => Color.Default
        };
    }

    private static Color GetPriorityColor(
        string priority
    )
    {
        return priority switch
        {
            "High" => Color.Error,
            "Medium" => Color.Warning,
            "Low" => Color.Info,
            _ => Color.Default
        };
    }

    private static string FormatSeverity(
        string severity
    )
    {
        return severity switch
        {
            "Critical" => "Критическая",
            "Warning" => "Предупреждение",
            "Info" => "Информация",
            _ => severity
        };
    }

    private static string FormatPriority(
        string priority
    )
    {
        return priority switch
        {
            "High" => "Высокий",
            "Medium" => "Средний",
            "Low" => "Низкий",
            "Critical" => "Критический",
            _ => priority
        };
    }

    private static string FormatState(
        string state
    )
    {
        return state switch
        {
            "Active" => "Активна",
            "Acknowledged" => "Квитирована",
            "Cleared" => "Ушла",
            "Closed" => "Закрыта",
            "Shelved" => "Отложена",
            "Suppressed" => "Подавлена",
            _ => state
        };
    }
}