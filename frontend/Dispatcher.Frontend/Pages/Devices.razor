@page "/devices"

<PageTitle>Устройства - Dispatcher</PageTitle>

<div class="dispatcher-page">
    <MudText Typo="Typo.h4" HtmlTag="h1">Устройства</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        Основа модели устройств и подключений.
    </MudText>

    <MudPaper Elevation="0" Class="dispatcher-card mt-4">
        <MudText Typo="Typo.h6">Планируемое содержимое</MudText>

        <MudList T="string" Dense="true" Class="mt-2">
            <MudListItem Text="Список устройств" Icon="@Icons.Material.Filled.Memory" />
            <MudListItem Text="Состояние подключения" Icon="@Icons.Material.Filled.SettingsEthernet" />
            <MudListItem Text="Диагностика устройства" Icon="@Icons.Material.Filled.MonitorHeart" />
        </MudList>
    </MudPaper>

    <UiStatePanel Kind="UiStateKind.NotImplemented"
                  Title="@UiText.NotImplementedTitle"
                  Message="@UiText.DevicesNotImplementedMessage"
                  Class="mt-4" />
</div>