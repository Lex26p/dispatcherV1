@page "/runtime"

@inject IDispatcherApiClient ApiClient

<PageTitle>Текущие значения - Dispatcher</PageTitle>

<div class="dispatcher-page">
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
            <div>
                <MudText Typo="Typo.h4" HtmlTag="h1">Текущие значения</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    Срез текущих значений тегов и качества данных.
                </MudText>
            </div>

            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined">
                Демо-данные
            </MudChip>
        </MudStack>

        <UiStatePanel Kind="UiStateKind.MockData"
                      Title="@UiText.DemoDataTitle"
                      Message="@UiText.RuntimeDemoDataMessage" />

        <MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        Значений
                    </MudText>
                    <MudText Typo="Typo.h5" Class="mt-1">
                        @_values.Count
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        Значения в текущем демо-срезе.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        Хорошее качество
                    </MudText>
                    <MudText Typo="Typo.h5" Class="mt-1">
                        @GoodQualityCount
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        Значения с хорошим качеством.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        Требуют внимания
                    </MudText>
                    <MudText Typo="Typo.h5" Class="mt-1">
                        @BadOrUncertainCount
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        Значения с сомнительным качеством или ошибкой связи.
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="0" Class="dispatcher-card">
            <MudText Typo="Typo.h6">Таблица текущих значений</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                Эта таблица моделирует будущий экран текущих значений.
            </MudText>

            <MudTable T="RuntimeValueViewModel"
                      Items="_values"
                      Dense="true"
                      Hover="true"
                      Elevation="0"
                      Class="dispatcher-table">
                <HeaderContent>
                    <MudTh>Тег</MudTh>
                    <MudTh>Объект</MudTh>
                    <MudTh>Устройство</MudTh>
                    <MudTh>Значение</MudTh>
                    <MudTh>Качество</MudTh>
                    <MudTh>Время</MudTh>
                </HeaderContent>

                <RowTemplate Context="value">
                    <MudTd DataLabel="Тег">
                        <MudText Typo="Typo.body2">@value.TagCode</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@value.TagName</MudText>
                    </MudTd>

                    <MudTd DataLabel="Объект">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@value.ObjectPath</MudText>
                    </MudTd>

                    <MudTd DataLabel="Устройство">
                        <MudText Typo="Typo.body2">@value.DeviceName</MudText>
                    </MudTd>

                    <MudTd DataLabel="Значение">
                        <MudText Typo="Typo.body2">
                            @value.Value @value.Unit
                        </MudText>
                    </MudTd>

                    <MudTd DataLabel="Качество">
                        <MudChip T="string"
                                 Color="@GetQualityColor(value.Quality)"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small">
                            @FormatQuality(value.Quality)
                        </MudChip>
                    </MudTd>

                    <MudTd DataLabel="Время">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @value.Timestamp.ToString("HH:mm:ss")
                        </MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudStack>
</div>

@code {
    private IReadOnlyList<RuntimeValueViewModel> _values = [];

    private int GoodQualityCount =>
        _values.Count(value => string.Equals(value.Quality, "Good", StringComparison.OrdinalIgnoreCase));

    private int BadOrUncertainCount =>
        _values.Count(value => !string.Equals(value.Quality, "Good", StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _values = await ApiClient.GetRuntimeValuesAsync();
    }

    private static Color GetQualityColor(
        string quality
    )
    {
        return quality switch
        {
            "Good" => Color.Success,
            "Uncertain" => Color.Warning,
            "CommunicationError" => Color.Error,
            "Bad" => Color.Error,
            _ => Color.Default
        };
    }

    private static string FormatQuality(
        string quality
    )
    {
        return quality switch
        {
            "Good" => "Хорошее",
            "Uncertain" => "Сомнительное",
            "Bad" => "Плохое",
            "CommunicationError" => "Ошибка связи",
            "Timeout" => "Тайм-аут",
            "DeviceError" => "Ошибка устройства",
            "ProtocolError" => "Ошибка протокола",
            "OutOfRange" => "Вне диапазона",
            "Manual" => "Ручное",
            "Simulation" => "Симуляция",
            "Maintenance" => "Обслуживание",
            "Stale" => "Устарело",
            "Disabled" => "Отключено",
            "NotInitialized" => "Не инициализировано",
            _ => quality
        };
    }
}