@page "/system"

<PageTitle>System - Dispatcher</PageTitle>

<div class="dispatcher-page">
    <MudText Typo="Typo.h4" HtmlTag="h1">System</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        System overview placeholder.
    </MudText>

    <MudPaper Elevation="0" Class="dispatcher-card mt-4">
        <MudText Typo="Typo.h6">Planned content</MudText>

        <MudList T="string" Dense="true" Class="mt-2">
            <MudListItem Text="Backend module list" Icon="@Icons.Material.Filled.Extension" />
            <MudListItem Text="Gateway startup status" Icon="@Icons.Material.Filled.PowerSettingsNew" />
            <MudListItem Text="API route count" Icon="@Icons.Material.Filled.Route" />
            <MudListItem Text="Realtime gateway status" Icon="@Icons.Material.Filled.Sync" />
        </MudList>
    </MudPaper>
</div>