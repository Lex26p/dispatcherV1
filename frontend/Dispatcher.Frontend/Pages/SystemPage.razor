@page "/system"

@inject IDispatcherApiClient ApiClient

<PageTitle>Система - Dispatcher</PageTitle>

<div class="dispatcher-page">
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
            <div>
                <MudText Typo="Typo.h4" HtmlTag="h1">Система</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    Обзор состояния backend foundation и системных модулей.
                </MudText>
            </div>

            <MudChip T="string"
                     Color="Color.Warning"
                     Variant="Variant.Outlined">
                Демо-данные
            </MudChip>
        </MudStack>

        <UiStatePanel Kind="UiStateKind.MockData"
                      Title="@UiText.DemoDataTitle"
                      Message="@UiText.SystemDemoDataMessage" />

        <MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        Режим шлюза
                    </MudText>

                    <MudText Typo="Typo.h5" Class="mt-1">
                        @FormatGatewayMode(_gatewaySummary.Mode)
                    </MudText>

                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        @_gatewaySummary.Message
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        API-слой
                    </MudText>

                    <MudText Typo="Typo.h5" Class="mt-1">
                        @_apiSummary.RouteCount маршрутов
                    </MudText>

                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        @_apiSummary.ReadEndpointCount endpoints чтения
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        Реальное время
                    </MudText>

                    <MudText Typo="Typo.h5" Class="mt-1">
                        @_apiSummary.RealtimeChannelCount каналов
                    </MudText>

                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        WebSocket/SSE transport будет добавлен позже.
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="0" Class="dispatcher-card">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                <div>
                    <MudText Typo="Typo.h6">Backend-модули</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Модули, зарегистрированные в foundation-контуре dispatcher_server.
                    </MudText>
                </div>

                <MudChip T="string"
                         Color="Color.Success"
                         Variant="Variant.Filled"
                         Size="Size.Small">
                    @_modules.Count работает
                </MudChip>
            </MudStack>

            <MudTable T="BackendModuleViewModel"
                      Items="_modules"
                      Dense="true"
                      Hover="true"
                      Elevation="0"
                      Class="dispatcher-table">
                <HeaderContent>
                    <MudTh>Код</MudTh>
                    <MudTh>Название</MudTh>
                    <MudTh>Описание</MudTh>
                    <MudTh>Статус</MudTh>
                </HeaderContent>

                <RowTemplate Context="module">
                    <MudTd DataLabel="Код">
                        <MudText Typo="Typo.body2">@module.Code</MudText>
                    </MudTd>

                    <MudTd DataLabel="Название">
                        <MudText Typo="Typo.body2">@module.Name</MudText>
                    </MudTd>

                    <MudTd DataLabel="Описание">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @module.Description
                        </MudText>
                    </MudTd>

                    <MudTd DataLabel="Статус">
                        <MudChip T="string"
                                 Color="@GetModuleStatusColor(module.Status)"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small">
                            @FormatModuleStatus(module.Status)
                        </MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudStack>
</div>

@code {
    private IReadOnlyList<BackendModuleViewModel> _modules = [];
    private GatewaySummaryViewModel _gatewaySummary = new();
    private ApiRouteSummaryViewModel _apiSummary = new();

    protected override async Task OnInitializedAsync()
    {
        _modules = await ApiClient.GetBackendModulesAsync();
        _gatewaySummary = await ApiClient.GetGatewaySummaryAsync();
        _apiSummary = await ApiClient.GetApiRouteSummaryAsync();
    }

    private static Color GetModuleStatusColor(
        string status
    )
    {
        return string.Equals(status, "Running", StringComparison.OrdinalIgnoreCase)
            ? Color.Success
            : Color.Warning;
    }

    private static string FormatModuleStatus(
        string status
    )
    {
        return status switch
        {
            "Running" => "Работает",
            "Stopped" => "Остановлен",
            "Starting" => "Запускается",
            "Stopping" => "Останавливается",
            "Failed" => "Ошибка",
            _ => "Неизвестно"
        };
    }

    private static string FormatGatewayMode(
        string mode
    )
    {
        return mode switch
        {
            "ApiAndRealtime" => "API и реальное время",
            "ApiOnly" => "Только API",
            "RealtimeOnly" => "Только реальное время",
            _ => mode
        };
    }
}