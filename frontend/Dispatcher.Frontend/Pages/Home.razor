@page "/"

<PageTitle>Dispatcher</PageTitle>

<div class="dispatcher-page">
    <MudPaper Elevation="0" Class="dispatcher-hero">
        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
            <div>
                <MudText Typo="Typo.h3" HtmlTag="h1">Dispatcher</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    Minimal operator UI foundation for the Dispatcher SCADA platform.
                </MudText>
            </div>

            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined">
                Sprint 010
            </MudChip>
        </MudStack>
    </MudPaper>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="dispatcher-card">
                <MudText Typo="Typo.h6">Backend foundation</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                    Backend modules are already split into domain-oriented libraries.
                </MudText>

                <MudList T="string" Dense="true" Class="mt-2">
                    <MudListItem Text="Objects" />
                    <MudListItem Text="Devices" />
                    <MudListItem Text="Tags" />
                    <MudListItem Text="Runtime" />
                    <MudListItem Text="Historian" />
                    <MudListItem Text="Events" />
                    <MudListItem Text="Alarms" />
                    <MudListItem Text="API" />
                    <MudListItem Text="Realtime" />
                </MudList>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="dispatcher-card">
                <MudText Typo="Typo.h6">Frontend foundation</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                    This Blazor WebAssembly app is the starting point for the future operator workspace.
                </MudText>

                <MudList T="string" Dense="true" Class="mt-2">
                    <MudListItem Text="MudBlazor foundation" />
                    <MudListItem Text="Operator layout" />
                    <MudListItem Text="Sidebar navigation" />
                    <MudListItem Text="API client placeholder" />
                    <MudListItem Text="Future realtime client" />
                </MudList>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="dispatcher-card">
                <MudText Typo="Typo.h6">MVP focus</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                    The current sprint prepares a minimal operator interface and documents remaining MVP limitations.
                </MudText>

                <MudList T="string" Dense="true" Class="mt-2">
                    <MudListItem Text="System/modules page" />
                    <MudListItem Text="Runtime placeholder" />
                    <MudListItem Text="Events placeholder" />
                    <MudListItem Text="Alarms placeholder" />
                    <MudListItem Text="MVP stabilization" />
                </MudList>
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>