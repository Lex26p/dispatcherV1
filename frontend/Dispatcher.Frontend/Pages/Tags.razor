@page "/tags"

<PageTitle>Tags - Dispatcher</PageTitle>

<div class="dispatcher-page">
    <MudText Typo="Typo.h4" HtmlTag="h1">Tags</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        Tag model placeholder.
    </MudText>

    <MudPaper Elevation="0" Class="dispatcher-card mt-4">
        <MudText Typo="Typo.h6">Planned content</MudText>

        <MudList T="string" Dense="true" Class="mt-2">
            <MudListItem Text="Tag list" Icon="@Icons.Material.Filled.Label" />
            <MudListItem Text="Tag type" Icon="@Icons.Material.Filled.Category" />
            <MudListItem Text="Archive policy" Icon="@Icons.Material.Filled.Inventory" />
            <MudListItem Text="Quality" Icon="@Icons.Material.Filled.Verified" />
        </MudList>
    </MudPaper>
</div>