@page "/tags"

<PageTitle>Теги - Dispatcher</PageTitle>

<div class="dispatcher-page">
    <MudText Typo="Typo.h4" HtmlTag="h1">Теги</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        Основа модели тегов, адресации и качества значений.
    </MudText>

    <MudPaper Elevation="0" Class="dispatcher-card mt-4">
        <MudText Typo="Typo.h6">Планируемое содержимое</MudText>

        <MudList T="string" Dense="true" Class="mt-2">
            <MudListItem Text="Список тегов" Icon="@Icons.Material.Filled.Label" />
            <MudListItem Text="Тип тега" Icon="@Icons.Material.Filled.Category" />
            <MudListItem Text="Политика архивирования" Icon="@Icons.Material.Filled.Inventory" />
            <MudListItem Text="Качество значения" Icon="@Icons.Material.Filled.Verified" />
        </MudList>
    </MudPaper>

    <UiStatePanel Kind="UiStateKind.NotImplemented"
                  Title="@UiText.NotImplementedTitle"
                  Message="@UiText.TagsNotImplementedMessage"
                  Class="mt-4" />
</div>
