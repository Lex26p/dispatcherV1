@page "/objects"

<PageTitle>Объекты - Dispatcher</PageTitle>

<div class="dispatcher-page">
    <MudText Typo="Typo.h4" HtmlTag="h1">Объекты</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        Основа объектной модели Dispatcher.
    </MudText>

    <MudPaper Elevation="0" Class="dispatcher-card mt-4">
        <MudText Typo="Typo.h6">Планируемое содержимое</MudText>

        <MudList T="string" Dense="true" Class="mt-2">
            <MudListItem Text="Дерево объектов" Icon="@Icons.Material.Filled.AccountTree" />
            <MudListItem Text="Карточка объекта" Icon="@Icons.Material.Filled.Info" />
            <MudListItem Text="Зоны ответственности" Icon="@Icons.Material.Filled.Groups" />
        </MudList>
    </MudPaper>

    <UiStatePanel Kind="UiStateKind.NotImplemented"
                  Title="@UiText.NotImplementedTitle"
                  Message="@UiText.ObjectsNotImplementedMessage"
                  Class="mt-4" />
</div>
