@page "/events"

@inject IDispatcherApiClient ApiClient

<PageTitle>События - Dispatcher</PageTitle>

<div class="dispatcher-page">
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
            <div>
                <MudText Typo="Typo.h4" HtmlTag="h1">События</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    Журнал событий Dispatcher.
                </MudText>
            </div>

            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined">
                Демо-данные
            </MudChip>
        </MudStack>

        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            На этой странице пока отображаются демо-события.
            Реальное подключение к `/api/events` будет добавлено позже.
        </MudAlert>

        <MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        Событий
                    </MudText>
                    <MudText Typo="Typo.h5" Class="mt-1">
                        @_events.Count
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        Записи в текущем демо-журнале.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        Предупреждения
                    </MudText>
                    <MudText Typo="Typo.h5" Class="mt-1">
                        @WarningCount
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        События с важностью «Предупреждение».
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="dispatcher-card">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                        Критические
                    </MudText>
                    <MudText Typo="Typo.h5" Class="mt-1">
                        @CriticalCount
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        События с критической важностью.
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="0" Class="dispatcher-card">
            <MudText Typo="Typo.h6">Журнал событий</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                Эта таблица моделирует будущий журнал событий.
            </MudText>

            <MudTable T="EventRecordViewModel"
                      Items="_events"
                      Dense="true"
                      Hover="true"
                      Elevation="0"
                      Class="dispatcher-table">
                <HeaderContent>
                    <MudTh>Время</MudTh>
                    <MudTh>Категория</MudTh>
                    <MudTh>Важность</MudTh>
                    <MudTh>Источник</MudTh>
                    <MudTh>Сообщение</MudTh>
                    <MudTh>Корреляция</MudTh>
                </HeaderContent>

                <RowTemplate Context="eventRecord">
                    <MudTd DataLabel="Время">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @eventRecord.Timestamp.ToString("HH:mm:ss")
                        </MudText>
                    </MudTd>

                    <MudTd DataLabel="Категория">
                        <MudText Typo="Typo.body2">@FormatCategory(eventRecord.Category)</MudText>
                    </MudTd>

                    <MudTd DataLabel="Важность">
                        <MudChip T="string"
                                 Color="@GetSeverityColor(eventRecord.Severity)"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small">
                            @FormatSeverity(eventRecord.Severity)
                        </MudChip>
                    </MudTd>

                    <MudTd DataLabel="Источник">
                        <MudText Typo="Typo.body2">@eventRecord.SourceName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @FormatSourceType(eventRecord.SourceType)
                        </MudText>
                    </MudTd>

                    <MudTd DataLabel="Сообщение">
                        <MudText Typo="Typo.body2">@eventRecord.Message</MudText>
                    </MudTd>

                    <MudTd DataLabel="Корреляция">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @eventRecord.CorrelationId
                        </MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudStack>
</div>

@code {
    private IReadOnlyList<EventRecordViewModel> _events = [];

    private int WarningCount =>
        _events.Count(eventRecord => string.Equals(eventRecord.Severity, "Warning", StringComparison.OrdinalIgnoreCase));

    private int CriticalCount =>
        _events.Count(eventRecord => string.Equals(eventRecord.Severity, "Critical", StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _events = await ApiClient.GetEventsAsync();
    }

    private static Color GetSeverityColor(
        string severity
    )
    {
        return severity switch
        {
            "Info" => Color.Info,
            "Warning" => Color.Warning,
            "Critical" => Color.Error,
            "Error" => Color.Error,
            _ => Color.Default
        };
    }

    private static string FormatSeverity(
        string severity
    )
    {
        return severity switch
        {
            "Info" => "Информация",
            "Warning" => "Предупреждение",
            "Critical" => "Критическая",
            "Error" => "Ошибка",
            _ => severity
        };
    }

    private static string FormatCategory(
        string category
    )
    {
        return category switch
        {
            "Runtime" => "Текущие значения",
            "Polling" => "Опрос",
            "Historian" => "История",
            "Alarms" => "Аварии",
            "System" => "Система",
            _ => category
        };
    }

    private static string FormatSourceType(
        string sourceType
    )
    {
        return sourceType switch
        {
            "Tag" => "Тег",
            "Device" => "Устройство",
            "Alarm" => "Авария",
            "System" => "Система",
            _ => sourceType
        };
    }
}