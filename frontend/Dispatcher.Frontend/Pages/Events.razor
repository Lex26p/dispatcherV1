@page "/events"

<PageTitle>Events - Dispatcher</PageTitle>

<div class="dispatcher-page">
    <MudText Typo="Typo.h4" HtmlTag="h1">Events</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        Event journal placeholder.
    </MudText>

    <MudPaper Elevation="0" Class="dispatcher-card mt-4">
        <MudText Typo="Typo.h6">Planned content</MudText>

        <MudList T="string" Dense="true" Class="mt-2">
            <MudListItem Text="Event records" Icon="@Icons.Material.Filled.Article" />
            <MudListItem Text="Severity" Icon="@Icons.Material.Filled.PriorityHigh" />
            <MudListItem Text="Source type" Icon="@Icons.Material.Filled.Input" />
            <MudListItem Text="Correlation id" Icon="@Icons.Material.Filled.Tag" />
        </MudList>
    </MudPaper>
</div>