<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>

    <NotFound>
        <PageTitle>Страница не найдена - Dispatcher</PageTitle>

        <LayoutView Layout="@typeof(MainLayout)">
            <MudContainer MaxWidth="MaxWidth.False" Class="dispatcher-page">
                <MudText Typo="Typo.h4" HtmlTag="h1">Страница не найдена</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    Запрошенный раздел Dispatcher пока не существует.
                </MudText>
            </MudContainer>
        </LayoutView>
    </NotFound>
</Router>