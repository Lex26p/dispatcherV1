{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-vs2026-x64-base",
      "displayName": "Windows VS 2026 x64 Base",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x64-debug",
      "displayName": "x64 Debug",
      "description": "Dispatcher Debug build for Windows x64 using Visual Studio 2026 generator and vcpkg manifest mode.",
      "inherits": "windows-vs2026-x64-base"
    },
    {
      "name": "x64-release",
      "displayName": "x64 Release",
      "description": "Dispatcher Release build for Windows x64 using Visual Studio 2026 generator and vcpkg manifest mode.",
      "inherits": "windows-vs2026-x64-base"
    }
  ],
  "buildPresets": [
    {
      "name": "x64-debug",
      "displayName": "Build x64 Debug",
      "configurePreset": "x64-debug",
      "configuration": "Debug"
    },
    {
      "name": "x64-release",
      "displayName": "Build x64 Release",
      "configurePreset": "x64-release",
      "configuration": "Release"
    }
  ]
}
