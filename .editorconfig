root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{bat,cmd}]
end_of_line = crlf

[*.{png,jpg,jpeg,gif,ico,pdf,zip,7z,dll,exe,pdb}]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset